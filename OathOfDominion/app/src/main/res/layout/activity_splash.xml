<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Glow effect behind logo -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/glow_circle"
        android:alpha="0.35"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVerticalBias="0.35"/>

    <!-- Demon mascot logo -->
    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_demon_logo"
        android:scaleType="fitCenter"
        android:contentDescription="Oath of Dominion"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVerticalBias="0.33"/>

    <!-- App title -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OATH OF DOMINION"
        android:textColor="@color/gold"
        android:textSize="20sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/splash_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GRAND ARENA COMPANION"
        android:textColor="@color/fire_orange"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/splash_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Season 1 · Week 12"
        android:textColor="@color/muted"
        android:textSize="9sp"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
