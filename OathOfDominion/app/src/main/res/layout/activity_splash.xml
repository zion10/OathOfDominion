<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#08090F">

    <ImageView
        android:id="@+id/splash_logo"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_demon_logo"
        android:scaleType="fitCenter"
        android:contentDescription="Oath of Dominion"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OATH OF DOMINION"
        android:textColor="#E8A020"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <TextView
        android:id="@+id/splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GRAND ARENA COMPANION"
        android:textColor="#FF6600"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:layout_marginTop="8dp"/>

</LinearLayout>
